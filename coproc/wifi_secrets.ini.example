; Template for coproc/wifi_secrets.ini — copy this file to
; wifi_secrets.ini and fill in your real network credentials.
;
;   cp wifi_secrets.ini.example wifi_secrets.ini
;
; wifi_secrets.ini is git-ignored (.gitignore: *_secrets.ini) so the
; real values never get committed. platformio.ini picks it up through
; its extra_configs glob; the [wifi] section here overrides the
; placeholder one in platformio.ini.
[wifi]
ssid = your-ssid
pass = your-password
